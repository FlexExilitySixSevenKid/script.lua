                                    FruitEspObjects[obj]   = FruitEspObjects[obj] or {}
                                    FruitEspObjects[obj].Box = FruitEspObjects[obj].Box or NewDraw("Square", {Thickness=3, Filled=false, Color=Color3.fromRGB(255,215,0)})
