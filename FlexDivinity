                                    FruitEspObjects[obj].Box.Size     = sz
                                    FruitEspObjects[obj].Box.Position = Vector2.new(fPos.X - sz.X/2, fPos.Y - sz.Y/2)
                                    FruitEspObjects[obj].Box.Visible  = true
                                    FruitEspObjects[obj].Text = FruitEspObjects[obj].Text or NewDraw("Text", {Size=18, Center=true, Outline=true, Color=Color3.fromRGB(255,215,0)})
